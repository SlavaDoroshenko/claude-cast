<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base theme — AppCompat без ActionBar, работает на любом Android TV -->
    <style name="Theme.ScreenMirrorTV" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#7C6FFF</item>
        <item name="colorPrimaryDark">#0F0F1A</item>
        <item name="colorAccent">#00D4AA</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Fullscreen theme для MirrorActivity -->
    <style name="Theme.ScreenMirrorTV.Fullscreen" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>
